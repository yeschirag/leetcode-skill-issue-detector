{
  "manifest_version": 3,
  "name": "LeetCode Meme Sounds",
  "version": "1.1",
  "description": "Plays meme sounds based on LeetCode submission results.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetCode Sounds"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["nice.mp3", "faahh.mp3"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
